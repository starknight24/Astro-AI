# Actual values live in per-package env files, NOT this repo root:
#   web/.env  (frontend, VITE_-prefixed vars only)
#   api/.env  (server, secrets)
# This file lists variable *names* only.

# --- web/.env ---
# Public Supabase URL and the publishable anon key (sb_publishable_...).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# API base URL. Empty in dev (vite proxy handles /api and /health).
VITE_API_URL=

# --- api/.env ---
# Supabase project URL (used to fetch the JWKS for verifying user JWTs).
SUPABASE_URL=
# Postgres connection string. SECRET — server-side only.
DATABASE_URL=
# Google Generative AI key. SECRET — server-side only.
GEMINI_API_KEY=
# Allowed browser origin for CORS.
WEB_ORIGIN=
